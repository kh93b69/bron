# ============================================================
# CyberBook — environment variables
# Скопируй в .env.local для локальной разработки.
# В Railway проставляй через Variables (Project → Settings).
# ============================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Supabase ---
# Из Supabase Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
# ВАЖНО: service-role key ТОЛЬКО на сервере. Не экспортировать через NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret>

# --- Email (Resend) ---
# https://resend.com → API Keys
RESEND_API_KEY=<resend-key>
EMAIL_FROM="CyberBook <noreply@cyberbook.local>"

# --- Web Push (VAPID) ---
# Сгенерировать: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@cyberbook.local"

# --- Cron / webhook secrets ---
# Любая длинная случайная строка (openssl rand -hex 32). Railway Scheduled Jobs шлёт её в header.
CRON_SECRET=<random-hex-32-bytes>
